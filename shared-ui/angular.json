{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "shared-ui": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "shared-ui:build-storybook",
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "shared-ui:build-sb-internal"
          }
        },
        "build-sb-internal": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "tsConfig": ".storybook/tsconfig.json",
            "outputPath": "dist/storybook-static",
            "main": "src/public-api.ts",
            "polyfills": ["zone.js"],
            "assets": [],
            "styles": [],
            "scripts": []
          }
        }
      }
    }
  }
}
